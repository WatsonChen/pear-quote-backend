# Local backend development
PORT=3001
FRONTEND_URL=http://localhost:3000
BASE_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/pear_quote

# Auth
JWT_SECRET=replace-with-local-jwt-secret

# Optional: AI features
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_ROUGH_ESTIMATE_MODEL=gemini-2.0-flash
GEMINI_ROUGH_ESTIMATE_FALLBACK_MODEL=gemini-2.5-pro
GEMINI_ANALYZE_MODEL=gemini-2.0-flash
GEMINI_ANALYZE_FALLBACK_MODEL=gemini-2.5-pro
GEMINI_ANALYTICS_MODEL=gemini-2.0-flash
GEMINI_QUEUE_GAP_MS=900
GEMINI_QUEUE_MAX_WAIT_MS=12000
ROUGH_ESTIMATE_QUEUE_WAIT_MS=4500
ANALYZE_QUEUE_WAIT_MS=12000
ROUGH_ESTIMATE_MAX_DESCRIPTION_CHARS=1400
ROUGH_ESTIMATE_DAILY_LIMIT=0

# Optional: payment integration
BACKEND_PUBLIC_URL=http://localhost:3001
NEWEBPAY_PUBLIC_BASE_URL=
NEWEBPAY_CLIENT_BACK_URL=http://localhost:3000/admin/settings?tab=billing
NEWEBPAY_SERVER_BACK_URL=http://localhost:3001/api/payments/return
