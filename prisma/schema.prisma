// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id               String @id @default(uuid())
  name             String
  subscriptionPlan String @default("FREE") // "FREE" or "PRO"
  creditBalance    Int    @default(0)

  // Payment integration
  ecpayToken      String?
  nextBillingDate DateTime?

  users     WorkspaceUser[]
  quotes    Quote[]
  customers Customer[]
  settings  SystemSettings?
  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkspaceUser {
  userId      String
  workspaceId String
  role        String @default("MEMBER") // "OWNER", "ADMIN", "MEMBER"

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([userId, workspaceId])
}

model Order {
  id          String    @id @default(uuid())
  orderNo     String    @unique // For ECPay MerchantTradeNo
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  amount        Int
  creditsAdded  Int
  status        String  @default("PENDING") // "PENDING", "PAID", "FAILED"
  paymentMethod String?

  // ECPay specific
  tradeNo     String? // ECPay TradeNo
  paymentDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Quote {
  id String @id @default(uuid())

  // Customer Relation
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id])
  customerName String // Keep for display/snapshot purposes

  projectName  String
  projectType  String
  expectedDays Int?
  description  String?
  status       String  @default("DRAFT")

  // Financials
  totalAmount Float?
  wonAmount   Float? // Actual deal amount when status is WON
  totalMargin Float?
  totalCost   Float?

  // Terms and Rates
  roleRates    Json? // Optional project-scoped role rates
  materials    Json? // Optional project-scoped materials
  paymentTerms String?
  validityDays Int?    @default(30)

  // Workspace Relation
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  items QuoteItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id          String  @id @default(uuid())
  name        String
  industry    String?
  description String?
  aiSummary   String?
  email       String?
  phone       String?
  type        String  @default("company") // "company" or "personal"
  taxId       String?

  // Workspace Relation
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  quotes Quote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuoteItem {
  id      String @id @default(uuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  description    String
  type           String  @default("service") // "service" or "material"
  estimatedHours Float? // Optional for material
  suggestedRole  String? // Optional for material
  unit           String? // For material e.g. "kg", "pc"
  hourlyRate     Float // Or unit price for material
  amount         Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSettings {
  id           String  @id @default(uuid())
  companyName  String?
  taxId        String?
  contactEmail String?

  // Rates
  juniorRate Float?
  seniorRate Float?
  pmRate     Float?
  designRate Float?
  roleRates  Json? // Array of { role: String, rate: Number }

  // Margin
  targetMarginMin Float?
  targetMarginMax Float?

  // Stamps
  companySealUrl               String?
  companyRepresentativeSealUrl String?

  // Project Types (Customizable)
  projectTypes Json? // Array of { value: String, label: String }

  // Materials (New)
  materials Json? // Array of { id: String, name: String, unit: String, price: Number }

  // Quote Configuration
  quoteValidityDays Int? @default(30)

  // Workspace Relation
  workspaceId String    @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  updatedAt DateTime @updatedAt
}

model User {
  id           String          @id @default(uuid())
  email        String          @unique
  passwordHash String?
  phoneNumber  String?         @unique // For SMS verification
  otpCode      String?
  otpExpiresAt DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  workspaces   WorkspaceUser[]
}
