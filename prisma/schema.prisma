generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id               String          @id @default(uuid())
  name             String
  subscriptionPlan String          @default("FREE")
  creditBalance    Int             @default(20)
  ecpayToken       String?
  nextBillingDate  DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  customers              Customer[]
  orders                 Order[]
  quotes                 Quote[]
  settings               SystemSettings?
  users                  WorkspaceUser[]
  estimateSnapshots      EstimateSnapshot[]
  estimateAdjustments    EstimateAdjustment[]
  calibrationProfile     TeamCalibrationProfile?
  calibrationAuditLogs   CalibrationAuditLog[]
}

model WorkspaceUser {
  userId      String
  workspaceId String
  role        String    @default("MEMBER")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([userId, workspaceId])
}

model Order {
  id            String    @id @default(uuid())
  orderNo       String    @unique
  workspaceId   String
  amount        Int
  creditsAdded  Int
  status        String    @default("PENDING")
  paymentMethod String?
  tradeNo       String?
  paymentDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
}

model Quote {
  id           String      @id @default(uuid())
  createdAt    DateTime    @default(now())
  customerName String
  description  String?
  expectedDays Int?
  projectName  String
  projectType  String
  generationType String     @default("quote")
  status       String      @default("DRAFT")
  totalAmount  Float?
  updatedAt    DateTime    @updatedAt
  customerId   String?
  totalCost    Float?
  totalMargin  Float?
  paymentTerms String?
  validityDays Int?        @default(30)
  wonAmount    Float?
  workspaceId  String
  materials    Json?
  roleRates    Json?
  shareToken   String?     @unique @default(uuid())
  shareViewedAt DateTime?
  lastViewedAt DateTime?
  viewCount    Int         @default(0)
  proposalStatus String    @default("draft")
  acceptedAt   DateTime?
  clientResponseName String?
  clientResponseEmail String?
  clientResponseMessage String?
  proposalContent Json?
  proposalTheme Json?
  customer          Customer?          @relation(fields: [customerId], references: [id])
  workspace         Workspace          @relation(fields: [workspaceId], references: [id])
  items             QuoteItem[]
  estimateSnapshots EstimateSnapshot[]
}

model Customer {
  id          String    @id @default(uuid())
  name        String
  industry    String?
  description String?
  aiSummary   String?
  email       String?
  phone       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  taxId       String?
  type        String    @default("company")
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  quotes      Quote[]
}

model QuoteItem {
  id             String   @id @default(uuid())
  quoteId        String
  description    String
  estimatedHours Float?
  suggestedRole  String?
  hourlyRate     Float
  aiSuggestedHourlyRate Float?
  configuredHourlyRate Float?
  rateSource     String?
  amount         Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  type           String   @default("service")
  unit           String?
  quote          Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model EstimateSnapshot {
  id                        String              @id @default(uuid())
  workspaceId               String
  quoteId                   String?
  baselineVersion           String              @default("1")
  detectedModules           Json
  baselineHours             Json
  complexityMultiplier      Float               @default(1.0)
  riskBuffer                Float               @default(0)
  rawGlobalEstimate         Json                // Before team calibration — immutable record
  calibratedEstimate        Json?               // After team calibration applied at generation time
  calibrationFactorsApplied Json?               // Snapshot of profile factors used at generation time
  originalHoursRange        Json
  confidenceScore           Float?
  missingInfo               Json?
  projectRiskFlags          Json?
  requirementSpec           Json?
  createdAt                 DateTime            @default(now())
  workspace                 Workspace           @relation(fields: [workspaceId], references: [id])
  quote                     Quote?              @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  adjustment                EstimateAdjustment?
}

model EstimateAdjustment {
  id                    String           @id @default(uuid())
  snapshotId            String           @unique
  workspaceId           String
  adjustedModules       Json?
  adjustedHoursByRole   Json?            // User's manual hour adjustments (pricing strategy, not actual)
  actualHoursByRole     Json?            // Actual tracked hours after project completion (estimateCalibration source)
  adjustedEstimateRange Json?
  adjustmentReason      String?
  finalQuotedPrice      Float?
  acceptedPrice         Float?
  projectStatus         String           @default("draft")
  scopeChanged          Boolean          @default(false)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  snapshot              EstimateSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  workspace             Workspace        @relation(fields: [workspaceId], references: [id])
}

model TeamCalibrationProfile {
  id                             String    @id @default(uuid())
  workspaceId                    String    @unique
  estimateCalibrationFactors     Json?     // Based on actualHoursByRole (completed projects) — affects hours
  pricingCalibrationFactors      Json?     // Based on adjustedEstimateRange/finalQuotedPrice — affects price only
  projectTypeCalibrationFactors  Json?
  estimateSampleSize             Int       @default(0)
  pricingSampleSize              Int       @default(0)
  estimateConfidenceLevel        String    @default("low")
  pricingConfidenceLevel         String    @default("low")
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt
  workspace                      Workspace @relation(fields: [workspaceId], references: [id])
  auditLogs                      CalibrationAuditLog[]
}

model CalibrationAuditLog {
  id                      String                 @id @default(uuid())
  workspaceId             String
  profileId               String
  appliedBy               String                 // userId
  previousEstimateFactors Json?
  newEstimateFactors      Json?
  previousPricingFactors  Json?
  newPricingFactors       Json?
  reason                  String?
  appliedAt               DateTime               @default(now())
  workspace               Workspace              @relation(fields: [workspaceId], references: [id])
  profile                 TeamCalibrationProfile @relation(fields: [profileId], references: [id])
}

model SystemSettings {
  id                           String    @id @default(uuid())
  companyName                  String?
  taxId                        String?
  contactEmail                 String?
  juniorRate                   Float?
  seniorRate                   Float?
  pmRate                       Float?
  designRate                   Float?
  targetMarginMin              Float?
  targetMarginMax              Float?
  updatedAt                    DateTime  @updatedAt
  companyRepresentativeSealUrl String?
  companySealUrl               String?
  roleRates                    Json?
  projectTypes                 Json?
  materials                    Json?
  quoteValidityDays            Int?      @default(30)
  estimationBaselines          Json?
  workspaceId                  String    @unique
  workspace                    Workspace @relation(fields: [workspaceId], references: [id])
}

model User {
  id                   String          @id @default(uuid())
  email                String          @unique
  passwordHash         String?
  otpCode              String?
  otpExpiresAt         DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  phoneNumber          String?         @unique
  termsAcceptedAt      DateTime?
  termsVersionAccepted String?
  bookingUrl           String?
  workspaces           WorkspaceUser[]
}
