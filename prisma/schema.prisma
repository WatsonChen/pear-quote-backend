generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id               String          @id @default(uuid())
  name             String
  subscriptionPlan String          @default("FREE")
  creditBalance    Int             @default(20)
  ecpayToken       String?
  nextBillingDate  DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  customers        Customer[]
  orders           Order[]
  quotes           Quote[]
  settings         SystemSettings?
  users            WorkspaceUser[]
}

model WorkspaceUser {
  userId      String
  workspaceId String
  role        String    @default("MEMBER")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([userId, workspaceId])
}

model Order {
  id            String    @id @default(uuid())
  orderNo       String    @unique
  workspaceId   String
  amount        Int
  creditsAdded  Int
  status        String    @default("PENDING")
  paymentMethod String?
  tradeNo       String?
  paymentDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
}

model Quote {
  id           String      @id @default(uuid())
  createdAt    DateTime    @default(now())
  customerName String
  description  String?
  expectedDays Int?
  projectName  String
  projectType  String
  status       String      @default("DRAFT")
  totalAmount  Float?
  updatedAt    DateTime    @updatedAt
  customerId   String?
  totalCost    Float?
  totalMargin  Float?
  paymentTerms String?
  validityDays Int?        @default(30)
  wonAmount    Float?
  workspaceId  String
  materials    Json?
  roleRates    Json?
  customer     Customer?   @relation(fields: [customerId], references: [id])
  workspace    Workspace   @relation(fields: [workspaceId], references: [id])
  items        QuoteItem[]
}

model Customer {
  id          String    @id @default(uuid())
  name        String
  industry    String?
  description String?
  aiSummary   String?
  email       String?
  phone       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  taxId       String?
  type        String    @default("company")
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  quotes      Quote[]
}

model QuoteItem {
  id             String   @id @default(uuid())
  quoteId        String
  description    String
  estimatedHours Float?
  suggestedRole  String?
  hourlyRate     Float
  amount         Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  type           String   @default("service")
  unit           String?
  quote          Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id                           String    @id @default(uuid())
  companyName                  String?
  taxId                        String?
  contactEmail                 String?
  juniorRate                   Float?
  seniorRate                   Float?
  pmRate                       Float?
  designRate                   Float?
  targetMarginMin              Float?
  targetMarginMax              Float?
  updatedAt                    DateTime  @updatedAt
  companyRepresentativeSealUrl String?
  companySealUrl               String?
  roleRates                    Json?
  projectTypes                 Json?
  materials                    Json?
  quoteValidityDays            Int?      @default(30)
  workspaceId                  String    @unique
  workspace                    Workspace @relation(fields: [workspaceId], references: [id])
}

model User {
  id                   String          @id @default(uuid())
  email                String          @unique
  passwordHash         String?
  otpCode              String?
  otpExpiresAt         DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  phoneNumber          String?         @unique
  termsAcceptedAt      DateTime?
  termsVersionAccepted String?
  workspaces           WorkspaceUser[]
}
